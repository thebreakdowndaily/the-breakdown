# ============================================================
#  The Breakdown — Environment Configuration Template
#  Copy to .env and fill in your values.
#  NEVER commit .env to git.
# ============================================================

# ---- Deployment ----
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# ---- Google Search Console ----
# Get code from: https://search.google.com/search-console
# Use HTML tag verification method, paste the content value here
GOOGLE_SITE_VERIFICATION=your_verification_code_here

# ---- Supabase Database ----
SUPABASE_URL=https://lvfovvidtowadmnggzzf.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# ---- Session / Auth (for CMS admin panel) ----
SESSION_SECRET=a_long_random_string_at_least_32_chars

# ---- Monitoring ----
SENTRY_DSN=https://your_sentry_dsn_here

# ---- Local Development ----
PORT=3000
NODE_ENV=development

# ============================================================
#  Where to get each value:
#  CLOUDFLARE_API_TOKEN:   https://dash.cloudflare.com/profile/api-tokens
#  GOOGLE_SITE_VERIFICATION: https://search.google.com/search-console
#  SUPABASE values:        https://supabase.com/dashboard/project/lvfovvidtowadmnggzzf/settings/api
#  SENTRY_DSN:             https://sentry.io/settings/<org>/projects/the-breakdown/
# ============================================================
